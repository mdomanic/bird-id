# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in your values.  Never commit the real .env.
# ---------------------------------------------------------------------------

# --- Identification engine ---
# "local"  = free, on-device classifier. No API cost, runs on CPU. (default)
# "claude" = Claude vision API. Smarter (reasoning, field marks), but costs
#            credits per image and needs ANTHROPIC_API_KEY below.
BIRD_ID_ENGINE=local

# --- Claude API (only used when BIRD_ID_ENGINE=claude) ---
# Get a key at https://console.anthropic.com/  (Settings -> API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Model used for bird identification.  Opus 4.8 is the most capable (and the
# default).  For lower cost on a busy camera you can switch to a cheaper model:
#   claude-sonnet-4-6   (cheaper, still strong)
#   claude-haiku-4-5    (cheapest, fastest)
BIRD_ID_MODEL=claude-opus-4-8

# Optional: rough location, used as a hint to improve species accuracy.
# e.g. "Portland, Oregon, USA" or "Kent, UK".  Leave blank if you prefer.
LOCATION_HINT=

# --- Arlo account (cloud login) ---
ARLO_USERNAME=you@example.com
ARLO_PASSWORD=your-arlo-password

# Arlo requires two-factor auth.  The easiest hands-free option is email 2FA
# read automatically from your inbox over IMAP.  Point these at the SAME inbox
# Arlo sends its codes to.  (For Gmail, create an App Password.)
ARLO_TFA_TYPE=email
ARLO_TFA_SOURCE=imap
ARLO_TFA_HOST=imap.gmail.com
ARLO_TFA_PORT=993
ARLO_TFA_USERNAME=you@gmail.com
ARLO_TFA_PASSWORD=your-imap-app-password

# Comma-separated list of camera names to watch. Leave blank to watch ALL cameras.
ARLO_CAMERAS=

# --- Behaviour ---
# How many frames to sample from each recorded clip and send to Claude.
FRAMES_PER_CLIP=4
# Minimum confidence (0-1) required to log/notify a species.
MIN_CONFIDENCE=0.4
# Notify on: "all" detections, or only the first time a "new" species is seen.
NOTIFY_MODE=new

# --- Notifications (optional email) ---
# Leave EMAIL_TO blank to disable email. Desktop toasts work without this.
EMAIL_TO=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-smtp-app-password

# --- Dashboard ---
# Use 127.0.0.1 for laptop-only access. On a home server (e.g. a Proxmox LXC),
# set this to 0.0.0.0 so you can reach the dashboard from other devices on your
# LAN at http://<server-ip>:5000/.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5000
# Password for the web Settings page (any username, this password). Strongly
# recommended since that page edits secrets. Blank = unprotected (the page warns
# you). You can also set this from the Settings page itself once you're in.
DASHBOARD_PASSWORD=
